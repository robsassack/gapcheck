{
  "manifest_version": 3,
  "name": "GapCheck",
  "version": "0.1.0",
  "description": "Compares a selected job posting against your resume using on-device AI and semantic similarity.",
  "permissions": ["sidePanel", "storage", "activeTab", "scripting"],
  "action": {
    "default_title": "GapCheck",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
